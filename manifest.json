{
  "manifest_version": 3,
  "name": "PinsPad",
  "description": "Save the current tab to your PinsPad collection with one click.",
  "version": "1.0.0",
  "action": {
    "default_title": "Save to PinsPad",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://pinspad.com/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
